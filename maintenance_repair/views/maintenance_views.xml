<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Maintenance Request Form View Inherit -->
    <record id="hr_equipment_request_view_form_inherit_repair" model="ir.ui.view">
        <field name="name">maintenance.request.form.inherit.repair</field>
        <field name="model">maintenance.request</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_request_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='equipment_id']" position="after">
                <field name="copy_count" invisible="not equipment_id"/>
            </xpath>
        </field>
    </record>

    <!-- Maintenance Equipment Form View Inherit -->
    <record id="hr_equipment_view_form_inherit_repair" model="ir.ui.view">
        <field name="name">maintenance.equipment.form.inherit.repair</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_repairs" type="object" class="oe_stat_button" icon="fa-wrench">
                    <field string="Repairs" name="repair_count" widget="statinfo"/>
                </button>
                <button name="action_view_copies" type="object" class="oe_stat_button" icon="fa-file-text-o">
                    <field string="Copies" name="copy_count" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="product_id" />
                <field name="copy_value" />
            </xpath>
        </field>
    </record>

    <!-- Maintenance Request Kanban View Inherit -->
    <record id="hr_equipment_request_view_kanban_inherit_repair" model="ir.ui.view">
        <field name="name">maintenance.request.kanban.inherit.repair</field>
        <field name="model">maintenance.request</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_request_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='activity_ids']" position="after">
                <button name="action_create_repair_order" type="object" class="btn btn-primary btn-sm ms-2" icon="fa-wrench" title="Create Repair Order"/>
            </xpath>
        </field>
    </record>
</odoo>
